          { type: 'example', de: 'Sehr geehrte Damen und Herren', en: 'Dear Sir or Madam' },
          { type: 'example', de: 'Mit freundlichen Grüßen', en: 'With kind regards' },
          { type: 'tip', text: 'Always use formal "Sie" unless you know the person well' },
        ],
      },
    },
    { upsert: true, new: true }
  );

  const b1Lesson3 = await LessonModel.findOneAndUpdate(
    { moduleId: b1Module3._id, order: 1 },
    {
      $set: {
        moduleId: b1Module3._id,
        order: 1,
        title: 'Relative Clauses',
        objectives: ['Use der/die/das/dem', 'Build complex sentences'],
        contentBlocks: [
          { type: 'text', text: 'Relative clauses add information about nouns using der/die/das/dem.' },
          { type: 'example', de: 'Der Mann, der dort steht, ist mein Lehrer', en: 'The man who is standing there is my teacher' },
          { type: 'example', de: 'Das Buch, das ich lese, ist interessant', en: 'The book that I am reading is interesting' },
          { type: 'tip', text: 'The relative pronoun agrees with the noun it describes' },
        ],
      },
    },
    { upsert: true, new: true }
  );
  await ActivityModel.findOneAndUpdate(
    { parentType: 'lesson', parentId: a2Lesson1._id, order: 1 },
    {
      $set: {
        parentType: 'lesson',
        parentId: a2Lesson1._id,
        order: 1,
        type: 'perfekt_formation',
        prompt: 'Form the Perfekt tense with "haben".',
        payload: {
          items: [
            { infinitive: 'machen', answer: 'habe gemacht' },
            { infinitive: 'kaufen', answer: 'habe gekauft' },
            { infinitive: 'spielen', answer: 'habe gespielt' },
            { infinitive: 'arbeiten', answer: 'habe gearbeitet' },
          ],
        },
        scoring: { xpCorrect: 20, xpIncorrect: 4 },
      },
    },
    { upsert: true, new: true }
  );

  await ActivityModel.findOneAndUpdate(
    { parentType: 'lesson', parentId: a2Lesson2._id, order: 1 },
    {
      $set: {
        parentType: 'lesson',
        parentId: a2Lesson2._id,
        order: 1,
        type: 'case_selection',
        prompt: 'Choose the correct accusative article.',
        payload: {
          items: [
            { noun: 'Hund', article: 'der', answer: 'den' },
            { noun: 'Ball', article: 'der', answer: 'den' },
            { noun: 'Katze', article: 'die', answer: 'die' },
            { noun: 'Buch', article: 'das', answer: 'das' },
          ],
        },
        scoring: { xpCorrect: 15, xpIncorrect: 3 },
      },
    },
    { upsert: true, new: true }
  );

  // Activities for B1
  await ActivityModel.findOneAndUpdate(
    { parentType: 'lesson', parentId: b1Lesson1._id, order: 1 },
    {
      $set: {
        parentType: 'lesson',
        parentId: b1Lesson1._id,
        order: 1,
        type: 'subjunctive_formation',
        prompt: 'Form the Konjunktiv II for these situations.',
        payload: {
          items: [
            { situation: 'I would like', answer: 'Ich hätte gern' },
            { situation: 'If I had time', answer: 'Wenn ich Zeit hätte' },
            { situation: 'I would be happy', answer: 'Ich wäre glücklich' },
            { situation: 'You could help', answer: 'Du könntest helfen' },
          ],
        },
        scoring: { xpCorrect: 25, xpIncorrect: 5 },
      },
    },
    { upsert: true, new: true }
  );

  await ActivityModel.findOneAndUpdate(
    { parentType: 'lesson', parentId: b1Lesson2._id, order: 1 },
    {
      $set: {
        parentType: 'lesson',
        parentId: b1Lesson2._id,
        order: 1,
        type: 'business_phrases',
        prompt: 'Match the German business phrases with their English meanings.',
        payload: {
          items: [
            { german: 'Anlagen', english: 'Attachments', options: ['Attachments', 'Meeting', 'Deadline', 'Report'] },
            { german: 'Termin', english: 'Appointment', options: ['Appointment', 'Budget', 'Contract', 'Invoice'] },
            { german: 'Rechnung', english: 'Invoice', options: ['Invoice', 'Proposal', 'Schedule', 'Agenda'] },
            { german: 'Besprechung', english: 'Meeting', options: ['Meeting', 'Holiday', 'Project', 'Budget'] },
          ],
        },
        scoring: { xpCorrect: 20, xpIncorrect: 4 },
      },
    },
    { upsert: true, new: true }
  );

  await ActivityModel.findOneAndUpdate(
    { parentType: 'lesson', parentId: b1Lesson3._id, order: 1 },
    {
      $set: {
        parentType: 'lesson',
        parentId: b1Lesson3._id,
        order: 1,
        type: 'relative_pronouns',
        prompt: 'Choose the correct relative pronoun for each sentence.',
        payload: {
          items: [
            { sentence: 'Der Mann, ___ dort steht, ist mein Lehrer', answer: 'der', options: ['der', 'die', 'das', 'dem'] },
            { sentence: 'Das Buch, ___ ich lese, ist interessant', answer: 'das', options: ['der', 'die', 'das', 'dem'] },
            { sentence: 'Die Frau, ___ ich kenne, kommt aus Berlin', answer: 'die', options: ['der', 'die', 'das', 'dem'] },
            { sentence: 'Das Kind, ___ spielt, ist glücklich', answer: 'das', options: ['der', 'die', 'das', 'dem'] },
          ],
        },
        scoring: { xpCorrect: 20, xpIncorrect: 4 },
      },
    },
    { upsert: true, new: true }
  );

  // eslint-disable-next-line no-console
  console.log('Seed completed');
}

seed().catch((err) => {
  // eslint-disable-next-line no-console
  console.error(err);
  process.exit(1);
});
