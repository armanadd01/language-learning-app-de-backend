          { type: 'example', de: 'der Mann', en: 'the man (masculine)' },
          { type: 'example', de: 'die Frau', en: 'the woman (feminine)' },
          { type: 'example', de: 'das Kind', en: 'the child (neuter)' },
          { type: 'tip', text: 'Memorize the article with each noun - it\\'s essential!' },
