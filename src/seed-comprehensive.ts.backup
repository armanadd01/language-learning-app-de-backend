          { type: 'example', de: 'dreizehn, vierzehn, fünfzehn', en: 'thirteen, fourteen, fifteen' },
          { type: 'example', de: 'sechzehn, siebzehn, achtzehn', en: 'sixteen, seventeen, eighteen' },
          { type: 'example', de: 'neunzehn, zwanzig', en: 'nineteen, twenty' },
