          { type: 'example', de: 'über (over)', en: 'Ü sounds like "oo" in moon with rounded lips' },
          { type: 'example', de: 'Straße (street)', en: 'ß sounds like double "s"' },
          { type: 'tip', text: 'Practice these sounds daily - they\\'re crucial for good pronunciation!' },
